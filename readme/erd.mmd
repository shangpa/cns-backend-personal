    %% ── 재료 마스터 ──────────────────────────────
    unit {
        bigint id PK
        varchar name
        varchar kind
    }
    ingredient_master {
        bigint id PK
        varchar nameKo
        varchar category
        bigint default_unit_id FK
    }

    %% ── 레시피 ───────────────────────────────────
    recipe {
        bigint recipeId PK
        int user_id FK
        varchar title
        varchar category
        boolean isDraft
        int viewCount
        int likes
    }
    recipe_ingredient {
        bigint id PK
        bigint recipe_id FK
        bigint ingredient_id FK
        double quantity
    }
    like_recipe {
        bigint id PK
        int user_id FK
        bigint recipe_id FK
