        bigint id PK
        int user_id FK
        bigint recipe_id FK
    }
    review {
        bigint reviewId PK
        bigint recipe_id FK
        int user_id FK
        int rating
        varchar content
    }

    %% ── 팬트리 (현행 식재료 관리) ────────────────
    pantry {
        bigint id PK
        int user_id FK
        varchar name
        boolean isDefault
        int sortOrder
    }
    pantry_stock {
        bigint id PK
        bigint pantry_id FK
        bigint ingredient_id FK
        bigint unit_id FK
        decimal quantity
        varchar storage
        date expiresAt
    }
    pantry_history {
        bigint id PK
        bigint pantry_id FK
        bigint ingredient_id FK
        bigint unit_id FK
        bigint stock_id FK
        decimal changeQty
        varchar action
        varchar refType
        bigint refId
    }

    %% ── 동네주방 거래 ────────────────────────────
    trade_post {
        bigint tradePostId PK
        int user_id FK
        int buyer_id FK
        varchar title
        varchar status
        int price
        double latitude
        double longitude
    }
    saved_trade_post {
        bigint id PK
        int user_id FK
        bigint trade_post_id FK
    }
    tp_review {
        bigint tpReviewId PK
        bigint trade_post_id FK
        int user_id FK
        int rating
    }
    chat_rooms {
        bigint id PK
        varchar roomKey
        bigint post_id FK
        int user_a_id FK
        int user_b_id FK
    }

    %% ── 게시판 ───────────────────────────────────
    board {
        bigint id PK
        int writer_id FK
        varchar content
        varchar boardType
    }
    board_comment {
        bigint id PK
        int user_id FK
        bigint board_id FK
        varchar content
    }
    board_like {
        bigint id PK
        int user_id FK
        bigint board_id FK
    }

    %% ── 숏폼 ─────────────────────────────────────
    shorts_video {
        bigint id PK
        int user_id FK
        varchar title
        int viewCount
    }
    short_comment {
        bigint id PK
        int user_id FK
        bigint shorts_video_id FK
        varchar content
    }

    %% ── 사용자 부가 ──────────────────────────────
    user_follow {
        bigint id PK
        int follower_id FK
        int following_id FK
    }
    point_history {
        bigint id PK
        int user_id FK
